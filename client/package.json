{
  "name": "webchat-client",
  "version": "1.0.0",
  "description": "WebChat 即时通讯应用桌面客户端",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "cross-env ELECTRON_RUN_AS_NODE= NODE_ENV=development electron .",
    "electron:build": "npm run build && electron-builder --win --x64",
    "desktop:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:1420 && npm run electron:dev\"",
    "desktop:build": "npm run electron:build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@stomp/stompjs": "^7.3.0",
    "@tanstack/react-query": "^5.20.0",
    "@types/qrcode": "^1.5.6",
    "axios": "^1.6.7",
    "lucide-react": "^1.7.0",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.2",
    "react-window": "^2.2.7",
    "sockjs-client": "^1.6.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^1.5.3",
    "@tauri-apps/cli": "^1.5.9",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/react-window": "^1.8.8",
    "@types/sockjs-client": "^1.5.4",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "30.0.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.webchat.desktop",
    "productName": "WebChat",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "electron/icon.ico"
    ],
    "icon": "electron/icon.ico",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "webchat-setup-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WebChat"
    }
  }
}
